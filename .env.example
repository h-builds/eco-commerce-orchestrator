# Local development environment variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is in .gitignore.

# Required for ProductGrid.tsx SSR fetch() to resolve correctly.
# In Cloudflare Pages this is set automatically via the Pages dashboard.
# For local `next dev`, set it to your local server address.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
