# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all variants, but always commit the example template
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cloudflare
.wrangler/
.dev.vars

# Local Database Files (D1 / SQLite)
*.sqlite
*.sqlite3
*.db
*.db-journal

# Go (Microservices) — compiled output
services/pricing/bin/
services/pricing/obj/
services/pricing/*.exe
services/pricing/*.test
# Extensionless Linux binary produced by `go build` (e.g. `go build -o main .`)
services/pricing/main
services/pricing/main.wasm
# Copied from Go stdlib during wrangler build — not source, always regenerated
services/pricing/wasm_exec.js

# IDEs and Editors
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo

# OS Data Files
.DS_Store
Thumbs.db
Desktop.ini

# Secrets & Certificates
*.pem
*.key
*.cert
*.crt
*_rsa
id_rsa
*.p12
*.pfx

# AI / Agents Local Data
.aider*
.gemini/
.cursor/
.agents/
knowledge/
